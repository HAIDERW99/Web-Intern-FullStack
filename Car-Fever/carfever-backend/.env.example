# ─────────────────────────────────────────────────────────────────
# CarFever Backend — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# Port the Express server will listen on (Render sets this automatically)
PORT=5000

# Your Supabase project URL  (Settings → API → Project URL)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase service_role key  (Settings → API → service_role — keep this secret!)
# Use service_role (not anon) so the backend can bypass Row Level Security.
SUPABASE_KEY=your-supabase-service-role-key

# CORS — comma-separated list of allowed frontend origins
# e.g. http://localhost:5173,https://carfever.vercel.app
ALLOWED_ORIGINS=http://localhost:5173
